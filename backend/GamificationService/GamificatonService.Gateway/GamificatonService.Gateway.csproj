      <ProjectReference Include="..\Implementations\Storages\GamificatonService.PersistentStorage\GamificatonService.PersistentStorage.csproj" />
      <ProjectReference Include="..\Implementations\GamificatonService.Core\GamificatonService.Core.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Content Include="..\.dockerignore">
