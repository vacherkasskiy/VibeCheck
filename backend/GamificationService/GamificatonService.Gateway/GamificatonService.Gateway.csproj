            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\Implementations\GamificatonService.MessageBroker\GamificatonService.MessageBroker.csproj" />
      <ProjectReference Include="..\Implementations\Storages\GamificatonService.CacheStorage\GamificatonService.CacheStorage.csproj" />
