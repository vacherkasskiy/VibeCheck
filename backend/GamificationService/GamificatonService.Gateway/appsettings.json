{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "KafkaOptions": {
    "SecurityProtocol": "SaslPlaintext",
    "SaslMechanism": "Plain"
  },
  "ObservabilityOptions": {
    "MetricsPort": 9464,
    "MetricsEndpointPath": "/metrics"
  },
  "AllowedHosts": "*"
}
